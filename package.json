{
  "name": "neo",
  "version": "0.1.0",
  "description": "Neo — Personal AI Agent powered by GitHub Copilot SDK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "oxlint",
      "oxfmt --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "dependencies": {
    "@deepgram/sdk": "^5.0.0",
    "@github/copilot-sdk": "^0.1.32",
    "grammy": "^1.41.1",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
