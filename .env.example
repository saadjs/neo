# Telegram
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_OWNER_ID=            # Your Telegram user ID (from @userinfobot)

# GitHub Copilot
GITHUB_TOKEN=                 # GitHub PAT with Copilot access

# Optional
DEEPGRAM_API_KEY=             # Enable voice transcription
NEO_BROWSER_HEADLESS=true     # Default browser mode for Playwright sessions
NEO_BROWSER_LAUNCH_ARGS=      # Extra Chromium flags, space-separated
NEO_BROWSER_CREDENTIALS_JSON= # JSON object: {"site":{"username":"...","password":"..."}}
NEO_DATA_DIR=                 # Override data dir (default: $HOME/.neo; system service: /opt/neo/data)
NEO_LOG_DIR=                  # Override log dir (default: $HOME/.neo/logs; system service: /opt/neo/logs)
NEO_SYSTEMD_UNIT=             # Optional override; systemd service files set this automatically
NEO_SYSTEMCTL_SCOPE=          # Optional override; use system or user if you are not using the provided service files
GOOGLE_WORKSPACE_CLI_PATH=    # Optional path to the gws CLI binary
