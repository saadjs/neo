# Telegram
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_OWNER_ID=            # Your Telegram user ID (from @userinfobot)

# GitHub Copilot
GITHUB_TOKEN=                 # GitHub PAT with Copilot access

# Optional — defaults shown
COPILOT_MODEL=gpt-4.1         # Default LLM model
NEO_DATA_DIR=./data            # Memory files directory
NEO_LOG_DIR=./logs             # Log files directory
NEO_LOG_LEVEL=info             # error | warn | info | debug | trace
